; Engine configuration file.
; It's best edited using the editor UI and not directly,
; but it can also be manually edited if you know what you're doing.

[application]

config/name="ShotV"
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.3", "GL Compatibility")

[autoload]

Palette="*res://autoload/palette.gd"
GameData="*res://autoload/game_data.gd"
SaveManager="*res://autoload/save_manager.gd"
GameStore="*res://autoload/game_store.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

